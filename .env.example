# Google OAuth2 Credentials
# See README or Google Cloud Console to set these up.
GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here

# Optional: override redirect URI (for production, set to your deployed URL)
# GOOGLE_REDIRECT_URI=https://your-app.fly.dev/auth/google/callback

# Security (required in production, auto-generated in dev)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
SESSION_SECRET=

# Database path (defaults to ./data/tokens.db)
# DATABASE_PATH=./data/tokens.db
